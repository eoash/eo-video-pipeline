# Google Cloud Project
GOOGLE_CLOUD_PROJECT=ash-email-487014

# Gemini API Key (Google AI Studio에서 발급)
GEMINI_API_KEY=your-api-key-here

# Google Drive - 인제스트 폴더 ID
DRIVE_INGEST_FOLDER_ID=your-folder-id-here

# Google Sheets - 분석 결과 저장할 시트 ID
SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here

# Slack Incoming Webhook URL (분석 완료 알림)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# NAS 감시 경로 (watch-nas 모드용)
NAS_WATCH_DIR=/Volumes/EO_NAS/ingest

# 출력 경로 (FCPXML 마커 파일)
OUTPUT_DIR=./output
